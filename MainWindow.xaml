<Window x:Class="KanaSnake.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KanaSnake"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="800">
    <Grid Background="#1c1514">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Name="TargetText" Grid.Row = "0" FontSize="30" 
                HorizontalAlignment="Center" Margin="10" Foreground="White"/>

        <Canvas Name="GameCanvas" Grid.Row="1" 
        Width="420" Height="420" 
        Background="#69ad63" 
        HorizontalAlignment="Center" VerticalAlignment="Center"
        Margin="0,0,0,60"/>
    </Grid>
</Window>
