<Window x:Class="KanaSnake.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KanaSnake"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="800">
    <Grid Background="#1c1514">
        <StackPanel>
            <TextBlock Name="TargetText" FontSize="30" HorizontalAlignment="Center" Margin="10" Foreground="White"/>
            <Canvas Name="GameCanvas" Width="400" Height="400" Background="#69ad63"/>
        </StackPanel>    
    </Grid>
</Window>
