<Window x:Class="KanaSnake.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KanaSnake"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="800">
    <Grid Background="#1c1514">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            
            <Grid Width="420" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/> 
                    <ColumnDefinition Width="Auto"/> 
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Name="LivesText" 
                    Grid.Column="0" 
                    Text="❤❤❤" 
                    FontSize="24" 
                    Foreground="#FF4B4B" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Center"/>

                <TextBlock Name="TargetText" 
                    Grid.Column="1"
                    FontSize="48" 
                    Foreground="White" 
                    FontWeight="Bold" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center"/>

                <TextBlock Name="ScoreText" 
                    Grid.Column="2"
                    Text="0" 
                    FontSize="36" 
                    Foreground="#FFD700" 
                    FontWeight="Bold" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Center"/>
            </Grid>
            
            <Grid Width="420" Height="420" >
                <Canvas Name="GameCanvas" Grid.Row="1" 
                    Width="420" Height="420" 
                    Background="#69ad63" 
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    Margin="0,0,0,60"/>

                <Border Name="GameOverOverlay" 
                        Width="420" Height="420" 
                        Background="#AA000000" Visibility="Collapsed"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"> 

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Name="GameOverMessage" 
                                Text="GAME OVER" 
                                FontSize="36" 
                                Foreground="White" 
                                FontWeight="Bold" 
                                HorizontalAlignment="Center" 
                                Margin="0,0,0,20"/>
                            
                        <Button Content="TRY AGAIN" 
                                Padding="20,10" 
                                FontSize="20" 
                                Background="#FF4B4B" 
                                Foreground="White" 
                                FontWeight="Bold"
                                Click="RestartButton">

                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="10"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
